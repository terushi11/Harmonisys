generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(cuid())
  name                       String?
  email                      String              @unique
  emailVerified              DateTime?
  password                   String?
  image                      String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  competency                 Int?
  role                       UserType            @default(STANDARD)
  accounts                   Account[]
  Authenticator              Authenticator[]
  roleChangeRequestsReviewed RoleChangeRequest[] @relation("ReviewedBy")
  roleChangeRequests         RoleChangeRequest[] @relation("RoleChangeUser")
  sessions                   Session[]
  Unahon                     Unahon[]
}

model RoleChangeRequest {
  id           String        @id @default(cuid())
  userId       String
  fromRole     UserType
  toRole       UserType
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  updatedAt    DateTime      @default(now()) @updatedAt
  reviewedBy   User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  user         User          @relation("RoleChangeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Incident {
  id                  String           @id @default(cuid())
  location            String
  date                DateTime
  summary             String
  description         String
  category            IncidentCategory
  reporter            String?
  contact             String?
  severity            SeverityLevel
  attachments         String[]         @default([])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  teamDeployed        String
  otherCategoryDetail String?
  reviewNote          String?
  reviewedAt          DateTime?
  reviewedBy          String?
  status              IncidentStatus   @default(PENDING)
}

model Unahon {
  id             String         @id @default(cuid())
  client         String
  userId         String
  affiliation    String
  date           DateTime
  assessmentType AssessmentType
  checklist      Checklist[]
  responder      User           @relation(fields: [userId], references: [id])
}

model Checklist {
  agree    Boolean @default(false)
  disagree Boolean @default(false)
  unahonId String
  category Int
  key      Int
  Unahon   Unahon  @relation(fields: [unahonId], references: [id], onDelete: Cascade)

  @@id([category, key, unahonId])
}

model PlaceCoordinate {
  id        String @id @default(cuid())
  place     String @unique
  count     Int
  latitude  Float
  longitude Float
}

model Submission {
  id        String             @id @default(cuid())
  name      String
  date      DateTime
  team      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  responses QuestionResponse[]
}

model QuestionResponse {
  id             String     @id @default(cuid())
  questionId     Int
  questionText   String
  selectedOption String
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

enum IncidentStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
}

enum UserType {
  ADMIN
  RESPONDER
  STANDARD
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum IncidentCategory {
  SAFETY_HAZARD
  EQUIPMENT_MALFUNCTION
  SECURITY_BREACH
  NEAR_MISS
  ENVIRONMENTAL_SPILL
  OTHER
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssessmentType {
  INITIAL_ASSESSMENT
  RE_ASSESSMENT
}
