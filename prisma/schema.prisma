generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(cuid())
  name                       String?
  firstName                  String?
  lastName                   String?
  gender                     Gender?
  region                     String?
  mhpssLevel                 MhpssLevel?
  privacyPolicyAccepted      Boolean             @default(false)
  email                      String              @unique
  emailVerified              DateTime?
  password                   String?
  image                      String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  competency                 Int?
  role                       UserType            @default(STANDARD)
  accounts                   Account[]
  Authenticator              Authenticator[]
  roleChangeRequestsReviewed RoleChangeRequest[] @relation("ReviewedBy")
  roleChangeRequests         RoleChangeRequest[] @relation("RoleChangeUser")
  sessions                   Session[]
  Unahon                     Unahon[]
  incidents                  Incident[]
  submissions                Submission[]
  miSaludTeamsLed            MiSaludTeam[]              @relation("MiSaludTeamLeader")
  miSaludMemberships         MiSaludMembership[]
  miSaludRequests            MiSaludRequest[]           @relation("MiSaludRequestUser")
  miSaludRequestsReviewed    MiSaludRequest[]           @relation("MiSaludRequestReviewedBy")
  unahonReassessmentRequests UnahonReassessmentRequest[] @relation("UnahonReassessmentUser")
  unahonReassessmentAssigned UnahonReassessmentRequest[] @relation("UnahonReassessmentRequestedBy")
}

model RoleChangeRequest {
  id                  String        @id @default(cuid())
  userId              String
  fromRole            UserType
  toRole              UserType
  requestedMhpssLevel MhpssLevel?
  status              RequestStatus @default(PENDING)
  createdAt           DateTime      @default(now())
  reviewedAt          DateTime?
  reviewedById        String?
  updatedAt           DateTime      @default(now()) @updatedAt
  reviewedBy          User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  user                User          @relation("RoleChangeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Incident {
  id                  String           @id @default(cuid())
  userId              String
  location            String
  date                DateTime
  summary             String
  description         String
  category            IncidentCategory
  reporter            String?
  contact             String?
  severity            SeverityLevel
  attachments         String[]         @default([])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  teamDeployed        String
  otherCategoryDetail String?
  reviewNote          String?
  reviewedAt          DateTime?
  reviewedBy          String?
  status              IncidentStatus   @default(PENDING)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Unahon {
  id             String         @id @default(cuid())
  client         String
  userId         String
  affiliation    String
  date           DateTime
  assessmentType AssessmentType
  checklist      Checklist[]
  responder      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UnahonReassessmentRequest {
  id            String                    @id @default(cuid())
  userId        String
  requestedById String
  client        String?
  affiliation   String?
  status        UnahonReassessmentStatus  @default(PENDING)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  completedAt   DateTime?

  user          User                      @relation("UnahonReassessmentUser", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy   User                      @relation("UnahonReassessmentRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestedById])
  @@index([status])
}

model Checklist {
  agree    Boolean @default(false)
  disagree Boolean @default(false)
  unahonId String
  category Int
  key      Int
  Unahon   Unahon  @relation(fields: [unahonId], references: [id], onDelete: Cascade)

  @@id([category, key, unahonId])
}

model PlaceCoordinate {
  id        String @id @default(cuid())
  place     String @unique
  count     Int
  latitude  Float
  longitude Float
}

model Submission {
  id        String             @id @default(cuid())
  userId    String
  name      String
  date      DateTime
  team      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  responses QuestionResponse[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model QuestionResponse {
  id             String     @id @default(cuid())
  questionId     Int
  questionText   String
  selectedOption String
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model MiSaludTeam {
  id          String                @id @default(cuid())
  name        String                @unique
  leaderUserId String
  status      RequestStatus         @default(PENDING)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  reviewedAt  DateTime?
  reviewedById String?
  leader      User                  @relation("MiSaludTeamLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  memberships MiSaludMembership[]
  requests    MiSaludRequest[]
}

model MiSaludMembership {
  id          String           @id @default(cuid())
  userId      String
  teamId      String
  role        MiSaludTeamRole
  status      MembershipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  approvedAt  DateTime?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        MiSaludTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@index([status])
}

model MiSaludRequest {
  id              String           @id @default(cuid())
  userId          String
  fullName        String
  age             Int
  address         String
  requestedRole   MiSaludTeamRole
  teamName        String
  teamId          String?
  status          RequestStatus    @default(PENDING)
  reviewLevel     MiSaludReviewLevel
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  user            User             @relation("MiSaludRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy      User?            @relation("MiSaludRequestReviewedBy", fields: [reviewedById], references: [id])
  team            MiSaludTeam?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([reviewLevel])
}

enum IncidentStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
}

enum UserType {
  ADMIN
  RESPONDER
  STANDARD
}

enum Gender {
  MALE
  FEMALE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MhpssLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum IncidentCategory {
  SAFETY_HAZARD
  EQUIPMENT_MALFUNCTION
  SECURITY_BREACH
  NEAR_MISS
  ENVIRONMENTAL_SPILL
  OTHER
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssessmentType {
  INITIAL_ASSESSMENT
  RE_ASSESSMENT
}

enum UnahonReassessmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum MiSaludTeamRole {
  TEAM_LEADER
  TEAM_MEMBER
}

enum MiSaludReviewLevel {
  ADMIN
  TEAM_LEADER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}
